/**
 * Configuración de TypeScript para Cloud Functions de Firebase.
 * Esta configuración garantiza una compilación segura y eficiente.
 *
 * @see https://www.typescriptlang.org/docs/handbook/tsconfig-json.html
 */
{
  "compilerOptions": {
    /* Opciones de Tipado */
    "strict": true,                                /* Habilita todas las opciones de tipado estricto para un código más robusto. */
    "noImplicitReturns": true,                     /* Asegura que todas las funciones devuelvan un valor. */
    "noUnusedLocals": true,                        /* Detecta variables no utilizadas para un código más limpio. */
    "noFallthroughCasesInSwitch": true,            /* Evita 'caídas' en las estructuras de control 'switch'. */
    "forceConsistentCasingInFileNames": true,      /* Impone la consistencia en el uso de mayúsculas/minúsculas en los nombres de archivos. */

    /* Opciones del Módulo */
    "module": "commonjs",                          /* Utiliza el sistema de módulos CommonJS, que es el más compatible con Firebase Functions. */
    "target": "es2020",                            /* Compila a una versión moderna de JavaScript compatible con Node.js 18 y 20. */
    "lib": ["es2020"],                             /* Incluye librerías de tipos para ES2020. */
    "esModuleInterop": true,                       /* Habilita la interoperabilidad con módulos CommonJS para importaciones como `import * as express from 'express'`. */

    /* Opciones de Salida */
    "outDir": "lib",                               /* Directorio de salida para los archivos JavaScript compilados. */
    "sourceMap": true                              /* Genera archivos de mapa de origen para una fácil depuración. */
  },
  "compileOnSave": true,                           /* Compila automáticamente los archivos al guardarlos. */
  "include": [
    "src/**/*"                                     /* Incluye todos los archivos TypeScript de la carpeta 'src'. */
  ],
  "exclude": [
    "node_modules",                                /* Excluye el directorio 'node_modules' de la compilación. */
    "lib"                                          /* Excluye el directorio de salida para evitar errores de compilación. */
  ]
}
