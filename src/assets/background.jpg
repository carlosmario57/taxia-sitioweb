/* =================================================================================================
 * ARCHIVO: src/styles/background.css (Ejemplo de uso)
 * FUNCIÓN: Aplica una imagen de fondo a la página completa.
 * ================================================================================================= */

/*
 * Aplica la imagen de fondo al elemento <body> para que cubra toda la página.
 */
body {
  /* Define la imagen de fondo. Asegúrate de que la ruta sea correcta. */
  background-image: url('/assets/background.jpg');
  
  /* Ajusta el tamaño de la imagen para que siempre cubra todo el fondo. */
  background-size: cover;
  
  /* Centra la imagen de fondo. */
  background-position: center center;
  
  /* Evita la repetición de la imagen. */
  background-repeat: no-repeat;
  
  /* Mantiene la imagen fija al hacer scroll, creando un efecto de paralaje. */
  background-attachment: fixed;
  
  /* Asegura que el cuerpo ocupe al menos la altura completa de la pantalla. */
  min-height: 100vh;
}

