import React from 'react';
import { FaGem } from 'react-icons/fa';

/**
 * Componente funcional que renderiza un marcador de posición de logo.
 * Utiliza React-Icons para simular un ícono y Tailwind CSS para el estilo.
 */
const App = () => {
  return (
    <div className="flex items-center justify-center p-4">
      <div className="flex items-center space-x-2 bg-gradient-to-r from-blue-500 to-indigo-600 text-white rounded-xl p-4 shadow-lg transform transition-transform duration-300 hover:scale-105 cursor-pointer">
        {/* Usamos un icono de gema como un ejemplo de logo. */}
        <FaGem className="text-3xl" />
        <span className="text-2xl font-bold font-sans">
          App Logo
        </span>
      </div>
    </div>
  );
};

export default App;
